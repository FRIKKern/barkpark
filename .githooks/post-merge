#!/bin/bash
# Post-merge hook: nuke ALL compiled BEAM artifacts after git pull.
#
# Problem: Elixir HEEx templates are embedded into modules at compile time.
# When templates or modules change, old .beam files persist and Phoenix
# serves stale content. Cleaning just lib/sanity_api is NOT enough —
# template changes require a full _build/prod wipe.
#
# This is slow (recompiles deps ~60s) but prevents all stale artifacts.

if [ -d api/_build/prod ]; then
  echo "[post-merge] Nuking api/_build/prod (prevents stale BEAM/templates)..."
  rm -rf api/_build/prod
  echo "[post-merge] Run 'make rebuild' to recompile."
fi
