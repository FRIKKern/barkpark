#!/bin/bash
# Post-merge hook: clean stale BEAM cache after git pull.
#
# Problem: when Elixir modules are renamed/moved/deleted, old compiled
# .beam files persist in _build and Phoenix loads them instead of the
# new code. This causes ghost modules, 500 errors, and stale routes.
#
# Fix: delete the app's compiled output after every pull. Deps stay
# cached so recompile is fast (seconds, not minutes).

if [ -d api/_build/prod/lib/sanity_api ]; then
  echo "[post-merge] Cleaning stale BEAM cache..."
  rm -rf api/_build/prod/lib/sanity_api
  echo "[post-merge] Run 'make rebuild' to recompile."
fi
