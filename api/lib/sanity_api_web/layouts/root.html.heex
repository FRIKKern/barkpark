<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content={get_csrf_token()} />
  <title>Barkpark Studio</title>
  <style>
    :root {
      --bg: #0a0a0a; --bg-secondary: #141414; --bg-tertiary: #1a1a1a;
      --border: #27272a; --text: #e4e4e7; --text-dim: #71717a;
      --accent: #3b82f6; --accent-hover: #2563eb;
      --green: #34d399; --amber: #fbbf24; --red: #ef4444;
      --radius: 8px; --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font); background: var(--bg); color: var(--text); line-height: 1.5; }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Layout */
    .studio-layout { display: flex; height: 100vh; }
    .sidebar { width: 240px; background: var(--bg-secondary); border-right: 1px solid var(--border); padding: 16px 0; overflow-y: auto; flex-shrink: 0; }
    .sidebar-logo { padding: 0 16px 16px; font-size: 18px; font-weight: 700; color: var(--accent); }
    .sidebar-section { padding: 8px 16px 4px; font-size: 11px; text-transform: uppercase; color: var(--text-dim); letter-spacing: 0.05em; }
    .sidebar-item { display: flex; align-items: center; gap: 8px; padding: 8px 16px; color: var(--text); cursor: pointer; border-left: 3px solid transparent; }
    .sidebar-item:hover { background: var(--bg-tertiary); text-decoration: none; }
    .sidebar-item.active { background: var(--bg-tertiary); border-left-color: var(--accent); color: var(--accent); }
    .sidebar-divider { border-top: 1px solid var(--border); margin: 8px 16px; }
    .main { flex: 1; overflow-y: auto; padding: 24px 32px; }

    /* Cards */
    .card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 6px; font-size: 14px; font-weight: 500; cursor: pointer; border: 1px solid var(--border); background: var(--bg-tertiary); color: var(--text); }
    .btn:hover { background: var(--border); text-decoration: none; }
    .btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent-hover); }
    .btn-danger { background: var(--red); border-color: var(--red); color: #fff; }
    .btn-sm { padding: 4px 10px; font-size: 13px; }

    /* Status */
    .status { display: inline-flex; align-items: center; gap: 4px; font-size: 13px; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .status-published .status-dot { background: var(--green); }
    .status-draft .status-dot { background: var(--amber); }

    /* Doc list */
    .doc-list { list-style: none; }
    .doc-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-bottom: 1px solid var(--border); cursor: pointer; }
    .doc-item:hover { background: var(--bg-tertiary); }
    .doc-item:last-child { border-bottom: none; }
    .doc-title { font-weight: 500; }
    .doc-meta { font-size: 13px; color: var(--text-dim); }

    /* Forms */
    .form-group { margin-bottom: 20px; }
    .form-label { display: block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-dim); font-weight: 600; margin-bottom: 6px; }
    .form-input { width: 100%; padding: 10px 12px; background: var(--bg); border: 1px solid var(--border); border-radius: 6px; color: var(--text); font-size: 14px; font-family: var(--font); }
    .form-input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 2px rgba(59,130,246,0.2); }
    textarea.form-input { resize: vertical; min-height: 80px; }
    select.form-input { cursor: pointer; }
    .form-check { display: flex; align-items: center; gap: 8px; }

    /* Header */
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
    .page-title { font-size: 24px; font-weight: 700; }
    .page-subtitle { font-size: 14px; color: var(--text-dim); }

    /* Grid */
    .schema-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
    .schema-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; cursor: pointer; transition: border-color 0.15s; }
    .schema-card:hover { border-color: var(--accent); text-decoration: none; }
    .schema-icon { font-size: 24px; margin-bottom: 8px; }
    .schema-name { font-weight: 600; }
    .schema-visibility { font-size: 12px; color: var(--text-dim); }

    /* Media grid */
    .media-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
    .media-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; cursor: pointer; }
    .media-thumb { width: 100%; height: 120px; object-fit: cover; background: var(--bg-tertiary); display: flex; align-items: center; justify-content: center; color: var(--text-dim); font-size: 32px; }
    .media-info { padding: 8px; font-size: 12px; }

    /* Flash messages */
    .flash { padding: 10px 16px; border-radius: 6px; margin-bottom: 16px; font-size: 14px; }
    .flash-info { background: rgba(59,130,246,0.15); border: 1px solid var(--accent); }
    .flash-error { background: rgba(239,68,68,0.15); border: 1px solid var(--red); color: var(--red); }

    /* Toolbar */
    .toolbar { display: flex; gap: 8px; align-items: center; }

    /* Badge */
    .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 600; text-transform: uppercase; }
    .badge-public { background: rgba(52,211,153,0.15); color: var(--green); }
    .badge-private { background: rgba(251,191,36,0.15); color: var(--amber); }
  </style>
</head>
<body>
  {@inner_content}
</body>
</html>
