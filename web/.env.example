# Public Barkpark API base URL (browser-exposed; used by SSR + client builds).
# Production: https://api.barkpark.cloud
# Local dev:  http://localhost:4000
NEXT_PUBLIC_API_URL=https://api.barkpark.cloud

# Optional — only required when wiring draft mode (Phase 5+).
# Used as `serverToken` in @barkpark/nextjs/server config. Server-only.
# BARKPARK_READ_TOKEN=
