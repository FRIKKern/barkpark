{
  "name": "barkpark-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "npm --workspaces run build",
    "test": "npm --workspaces run test",
    "typecheck": "npm --workspaces run typecheck",
    "docs:mocks:check": "tsc --noEmit --project tooling/twoslash-mocks/tsconfig.json",
    "docs:reference": "typedoc --options tooling/typedoc/typedoc.json",
    "docs:reference:check": "typedoc --options tooling/typedoc/typedoc.json --emit none --logLevel Verbose"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "typedoc": "^0.26.0",
    "shiki-twoslash": "^3.1.3",
    "twoslash": "^0.2.12"
  }
}
