# Barkpark API base URL — server-side only. NEVER prefix with NEXT_PUBLIC_.
# Browsers cannot reach this HTTP host directly from the HTTPS Vercel frontend
# (mixed-content blocking). All fetches are routed through Next.js route handlers.
BARKPARK_API_URL=http://89.167.28.206

# Rotated weekly by the VPS systemd timer, which fires a Vercel deploy hook
# to redeploy this app with a fresh token. Server-side only.
BARKPARK_PUBLIC_READ_TOKEN=<rotated-weekly-via-systemd-timer>
