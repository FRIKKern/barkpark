{
  "name": "@barkpark/nextjs-query",
  "version": "0.0.0-placeholder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FRIKKern/barkpark.git",
    "directory": "js/packages/nextjs-query"
  },
  "license": "Apache-2.0",
  "description": "Reserved npm name for the Barkpark TanStack Query adapter — deferred to 1.1. See https://barkpark.dev/roadmap.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup && node ../../scripts/post-build-dts.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
