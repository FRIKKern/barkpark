{
  "name": "@barkpark/react",
  "version": "1.0.0-preview.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FRIKKern/barkpark.git",
    "directory": "js/packages/react"
  },
  "license": "Apache-2.0",
  "description": "Framework-free React renderers for Barkpark documents (PortableText, Image, Reference).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "react-server": {
        "types": "./dist/server.d.mts",
        "import": "./dist/server.mjs",
        "require": "./dist/server.cjs",
        "default": "./dist/server.mjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/post-build-dts.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "size": "size-limit"
  },
  "dependencies": {
    "@barkpark/core": "workspace:^"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@vitest/browser": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@testing-library/react": "^16.1.0",
    "happy-dom": "^15.11.0",
    "size-limit": "^11.1.0",
    "@size-limit/preset-small-lib": "^11.1.0"
  }
}
