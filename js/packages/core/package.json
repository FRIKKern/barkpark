{
  "name": "@barkpark/core",
  "version": "0.0.0",
  "license": "Apache-2.0",
  "description": "Runtime-agnostic HTTP client for the Barkpark headless CMS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup && node ../../scripts/post-build-dts.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "size": "size-limit"
  },
  "optionalDependencies": {
    "undici": "^6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "msw": "^2.4.0",
    "size-limit": "^11.1.0",
    "@size-limit/preset-small-lib": "^11.1.0"
  }
}
