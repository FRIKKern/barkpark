{
  "name": "@barkpark/core",
  "version": "1.0.0-preview.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FRIKKern/barkpark.git",
    "directory": "js/packages/core"
  },
  "license": "Apache-2.0",
  "description": "Runtime-agnostic HTTP client for the Barkpark headless CMS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && node ../../scripts/post-build-dts.mjs",
    "test": "vitest run -c vitest.config.ts",
    "test:workerd": "vitest run -c vitest.workerd.config.ts",
    "test:browser": "vitest run -c vitest.browser.config.ts",
    "test:all": "pnpm test && pnpm test:workerd && pnpm test:browser",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "size": "size-limit"
  },
  "optionalDependencies": {
    "undici": "^6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "msw": "^2.4.0",
    "size-limit": "^11.1.0",
    "@size-limit/preset-small-lib": "^11.1.0",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "miniflare": "^3.20240909.0",
    "@vitest/browser": "^2.1.0",
    "playwright": "^1.48.0",
    "happy-dom": "^15.11.0"
  }
}
