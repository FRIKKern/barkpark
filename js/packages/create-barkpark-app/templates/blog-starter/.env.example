# Barkpark API
BARKPARK_API_URL=http://localhost:4000
BARKPARK_DATASET=production

# Dev token — has read+write+admin. Only for local development.
BARKPARK_TOKEN=changeme-barkpark-dev-token

# Server-side token used by @barkpark/nextjs actions & draft mode. Keep secret.
BARKPARK_SERVER_TOKEN=changeme-barkpark-dev-token

# Preview secret (HMAC) used by @barkpark/nextjs draft-mode signed URLs.
BARKPARK_PREVIEW_SECRET=changeme-rotate-before-deploying

# Postgres (used by docker-compose)
POSTGRES_USER=barkpark
POSTGRES_PASSWORD=changeme-local-dev-only
POSTGRES_DB=barkpark_dev

# Phoenix
SECRET_KEY_BASE=changeme-generate-a-64-char-random-string-before-deploying-anywhere
PHX_HOST=localhost
