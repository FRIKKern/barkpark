import { createClient } from '@barkpark/core'

const projectUrl = process.env.BARKPARK_API_URL ?? 'http://localhost:4000'
const dataset = process.env.BARKPARK_DATASET ?? 'production'

export const barkparkClient = createClient({
  projectUrl,
  dataset,
  apiVersion: '2026-01-01',
})

export const projectConfig = {
  name: '{{projectName}}',
  dataset,
  projectUrl,
}
